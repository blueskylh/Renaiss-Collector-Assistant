# Renaiss Collector Assistant configuration
# Copy to .env or export in your shell. Never commit real secrets.

# Renaiss CLI talks to https://api.renaiss.xyz by default. Do not point it to index.renaissos.com.
# RENAISS_API_URL=https://api.renaiss.xyz
RENAISS_CLI_TIMEOUT=180

# Renaiss OS Index API. Public tier works without key but is limited to 10 requests/day/IP.
RENAISS_INDEX_API_BASE=https://api.renaissos.com
RENAISS_INDEX_API_KEY=
RENAISS_INDEX_API_SECRET=
# Index price arbitrage is key-gated by default because public quota is only 10 requests/day/IP.
RENAISS_INDEX_ARBITRAGE_SEARCH_LIMIT=3
RENAISS_INDEX_ARBITRAGE_INTER_REQUEST_DELAY=0.35

# Alchemy BNB Mainnet API. Used for wallet history via alchemy_getAssetTransfers
# and as the primary BSC receipt-decoding RPC. Never commit a real key.
# If ALCHEMY_BNB_RPC_URL is empty, scripts derive:
# https://bnb-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}
ALCHEMY_API_KEY=
ALCHEMY_BNB_RPC_URL=

# Public BSC RPC fallbacks for receipt decoding only. Wallet history needs
# Alchemy API key/RPC URL or another wallet-history source.
BSC_RPC_URL_1=https://bsc-dataseed.binance.org/
BSC_RPC_URL_2=https://bsc-dataseed1.defibit.io/
BSC_RPC_URL_3=https://bsc-dataseed1.ninicoin.io/

# Renaiss contracts discovered from wallet migration and Renaiss transaction traces.
BSC_USDT_CONTRACT=0x55d398326f99059ff775485246999027b3197955
RENAISS_NFT_CONTRACT=0xf8646a3ca093e97bb404c3b25e675c0394dd5b30
RENAISS_COLLECTIBLE_DIAMOND=0xb95f8867ff54fd16342cb414c0f57237be7dc512
RENAISS_SBT_CONTRACT=0x7d1b7db704d722295fbaa284008f526634673dbf
RENAISS_LEGACY_MIGRATION_HELPER=0x2e737d552b3c601ada4fcd167bfbd8d4e1043b2c
RENAISS_PACK_CONTRACT_CURRENT=0x94e7732b0b2e7c51ffd0d56580067d9c2e2b7910
RENAISS_PACK_CONTRACT_LEGACY_150=0xfda4a907d23d9f24271bc47483c5b983831e325e
RENAISS_PACK_OR_BUYBACK_LEGACY_88=0xb2891022648c5fad3721c42c05d8d283d4d53080
RENAISS_PACK_SETTLEMENT_CONTRACT=0xaab5f5fa75437a6e9e7004c12c9c56cda4b4885a
RENAISS_MARKETPLACE_PROXY=0xae3e7268ef5a062946216a44f58a8f685ffd11d0
BSC_ERC4337_ENTRYPOINT=0x0000000071727de22e5e9d8baf0edac6f37da032

# Arbitrage rule: seller pays 2% fee. Gas is ignored by default.
RENAISS_SELLER_FEE_RATE=0.02

# CLI detail calls are rate-sensitive. Stable test on 2026-07-10 observed c=3 with 6s spacing,
# but production defaults are intentionally more conservative.
RENAISS_CARD_DETAIL_METHOD=auto
RENAISS_CARD_DETAIL_API_THRESHOLD=10
RENAISS_CARD_API_BASE=https://api.renaiss.xyz/v0/cards
# CLI mode defaults for <=10 cards or fallback.
RENAISS_CARD_DETAIL_CONCURRENCY=2
RENAISS_CARD_DETAIL_MAX_CONCURRENCY=3
RENAISS_CARD_DETAIL_BATCH_SIZE=20
RENAISS_CARD_DETAIL_INTER_REQUEST_DELAY=8
RENAISS_CARD_DETAIL_BATCH_COOLDOWN=90
# API mode defaults for >10 cards. Keep one thread; the backend is Vercel WAF limited.
RENAISS_CARD_DETAIL_API_CONCURRENCY=1
RENAISS_CARD_DETAIL_API_BATCH_SIZE=10
RENAISS_CARD_DETAIL_API_INTER_REQUEST_DELAY=1
RENAISS_CARD_DETAIL_API_BATCH_COOLDOWN=5
RENAISS_CARD_DETAIL_FORBIDDEN_COOLDOWN=300
RENAISS_CARD_DETAIL_MAX_FORBIDDEN_PER_BATCH=1
RENAISS_CARD_DETAIL_RETRIES=1
RENAISS_CARD_DETAIL_TIMEOUT=120
